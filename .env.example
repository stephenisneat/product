# Hugeicons Pro (required to install @hugeicons-pro/*)
# Account → Tokens → Universal License Key: https://hugeicons.com/account/tokens
# Local: pnpm does not expand auth tokens from the project .npmrc — configure once:
#   pnpm config set //npm.hugeicons.com/:_authToken YOUR_KEY
# Vercel: set HUGEICONS_LICENSE_KEY for Production + Preview (Build). vercel.json
# installCommand writes it into .npmrc before pnpm install.
HUGEICONS_LICENSE_KEY=

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alias also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (required for wallet writes / Stripe webhooks)
# Dashboard → Project Settings → API → service_role
# Note: AI credit-balance gates are skipped in `next dev` even when this is set.
SUPABASE_SERVICE_ROLE_KEY=

# AI Gateway (optional — offline agent stream when unset locally)
# Local: run `vercel env pull .env.local` for VERCEL_OIDC_TOKEN (no API key needed)
# Or set a static key for CI / non-Vercel environments:
# AI_GATEWAY_API_KEY=
# On Vercel deployments, OIDC auth is automatic.

# App URL used for OAuth redirects (required for Shopify) and Stripe return URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Product Plugin runtime (tag loader / ingest). Defaults to local product-plugin.
# NEXT_PUBLIC_PLUGIN_URL=http://localhost:3001

# Stripe (required for wallet credits / payment methods / subscriptions)
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Dashboard → Developers → Webhooks → endpoint
#   POST https://<your-domain>/api/stripe/webhook
# Events: checkout.session.completed, payment_intent.succeeded, customer.updated,
#   customer.subscription.created, customer.subscription.updated,
#   customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=
# Subscription Price IDs (Dashboard → Products)
# Growth $29/seat/mo, Growth annual (~$278.40/seat/yr), Pro $99/seat/mo, Pro annual (~$950.40/seat/yr)
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=

# Shopify Partner app (optional until you enable import)
# Create an app in the Shopify Partner Dashboard, then set:
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Optional; defaults to read_products,read_inventory
# SHOPIFY_SCOPES=read_products,read_inventory
# Optional; defaults to hashing a commerce provider secret for token encryption
# TOKEN_ENCRYPTION_KEY=

# WooCommerce (optional — uses per-store REST API keys; needs TOKEN_ENCRYPTION_KEY
# or another commerce provider secret to encrypt stored credentials)
# WOOCOMMERCE_WEBHOOK_SECRET=

# BigCommerce (optional until you enable import)
# BIGCOMMERCE_CLIENT_ID=
# BIGCOMMERCE_CLIENT_SECRET=
# Optional; defaults to store_v2_products_read_only store_v2_information_read_only
# BIGCOMMERCE_SCOPES=store_v2_products_read_only store_v2_information_read_only

# Amazon Selling Partner API (optional until you enable import)
# AMAZON_LWA_CLIENT_ID=
# AMAZON_LWA_CLIENT_SECRET=
# AMAZON_SP_API_APP_ID=
# Optional; defaults to US marketplace + NA endpoint
# AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
# AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com
# AMAZON_SELLER_CENTRAL_URL=https://sellercentral.amazon.com

# Squarespace (optional until you enable import)
# SQUARESPACE_CLIENT_ID=
# SQUARESPACE_CLIENT_SECRET=
# Optional; defaults to website.products.read website.inventory.read
# SQUARESPACE_SCOPES=website.products.read website.inventory.read

# Google Ads API (optional until you enable channel connect)
# Create OAuth client in Google Cloud Console + developer token in Google Ads API Center:
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/google-ads/callback
# GOOGLE_ADS_REDIRECT_URI=
# Optional; defaults to https://www.googleapis.com/auth/adwords openid email
# GOOGLE_ADS_SCOPES=
# Optional; defaults to v19
# GOOGLE_ADS_API_VERSION=v19

# Meta Marketing API (optional until you enable channel connect)
# Create an app at https://developers.facebook.com/ — add Marketing API + redirect URI
META_APP_ID=
META_APP_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/meta/callback
# META_REDIRECT_URI=
# Optional; defaults to ads_management,ads_read,business_management,email
# META_SCOPES=
# Optional; defaults to v21.0
# META_API_VERSION=v21.0

# TikTok Marketing API (optional until you enable channel connect)
# Create an app in TikTok Ads Manager / Marketing API portal
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/tiktok/callback
# TIKTOK_ADS_REDIRECT_URI=

# Amazon Advertising API (optional; separate from Amazon SP-API commerce sync)
# Create an LWA security profile with Advertising API access
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/amazon-ads/callback
# AMAZON_ADS_REDIRECT_URI=
# Optional; defaults to advertising::campaign_management
# AMAZON_ADS_SCOPES=
# Optional regional endpoint; defaults to https://advertising-api.amazon.com (NA)
# AMAZON_ADS_API_URL=https://advertising-api.amazon.com

# X Ads API (optional until you enable channel connect)
# Create an OAuth 2.0 app at https://developer.x.com/ with offline.access
X_ADS_CLIENT_ID=
X_ADS_CLIENT_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/x-ads/callback
# X_ADS_REDIRECT_URI=
# Optional; defaults to offline.access tweet.read users.read
# X_ADS_SCOPES=
# Optional; defaults to 12
# X_ADS_API_VERSION=12

# Set to "true" to mark auth cookies Secure (also auto-enabled on Vercel)
# COOKIE_SECURE=true

# Auth setup (dashboard, not app env):
# 1. Authentication → URL configuration → Redirect URLs:
#    http://localhost:3000/auth/callback
#    https://<your-production-domain>/auth/callback
# 2. Authentication → Providers → enable Google (add Google Cloud OAuth client ID/secret there)
# 3. Keep email confirmations enabled for verification / change-email flows

# Resend (required for workspace email invites)
RESEND_API_KEY=
# Optional; defaults to Product Agent <onboarding@resend.dev>
# RESEND_FROM="Product Agent <onboarding@yourdomain.com>"

# Cursor Cloud Agents (Admin Center feedback → PR pipeline)
# Dashboard → Integrations / API Keys → create a user or service-account key
CURSOR_API_KEY=
# GitHub repo the agent should work in (PR target branch defaults to dev)
CURSOR_GITHUB_REPO_URL=https://github.com/stephenisneat/product
# CURSOR_AGENT_BASE_REF=dev
# Optional model id for launch; omit / "default" uses Cursor defaults
# CURSOR_AGENT_MODEL=default
# Signing secret for POST /api/webhooks/cursor/agent (min 32 chars)
CURSOR_WEBHOOK_SECRET=
# GitHub webhook secret for POST /api/webhooks/github (PR merged → email user)
# Create a repo webhook for "Pull requests" events pointing at:
#   ${NEXT_PUBLIC_APP_URL}/api/webhooks/github
GITHUB_WEBHOOK_SECRET=

# Trigger.dev (background jobs — create campaign, creatives, insights)
# Dashboard → Project → API Keys (use the matching DEV or PROD secret)
TRIGGER_SECRET_KEY=
# Project ref from the Trigger.dev dashboard (also set in trigger.config.ts via init)
# TRIGGER_PROJECT_ID=proj_...
# Workers need Supabase env in the Trigger dashboard too (not only on Vercel):
#   NEXT_PUBLIC_SUPABASE_URL = Project URL from Supabase → Settings → API
#     (https://<project-ref>.supabase.co — same as Vercel; not localhost)
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY
# Wrong URL → Supabase error "Project not specified."
# Then: pnpm exec trigger deploy

# ElevenLabs (video stage — TTS; voices auto-cast from the account library)
# Dashboard → Profile → API Key
ELEVENLABS_API_KEY=
# Optional: pin narrator / voiceover voice (otherwise auto-picked from library)
# ELEVENLABS_VOICE_ID=
# Optional: pin the first dialogue character's voice
# ELEVENLABS_DIALOGUE_VOICE_ID=

# Runway (video stage — Veo 3.1 image-to-video)
# Dashboard → API → API Keys (env name matches the SDK)
RUNWAYML_API_SECRET=
# Also set ELEVENLABS_* and RUNWAYML_API_SECRET on Trigger.dev workers.

# Shopify Partner app setup:
# 1. Create a custom/public app in Partners → Apps
# 2. Set Allowed redirection URL(s) to:
#    http://localhost:3000/api/integrations/shopify/callback
#    https://<your-production-domain>/api/integrations/shopify/callback
# 3. Request scopes: read_products, read_inventory
# 4. Copy Client ID → SHOPIFY_API_KEY and Client secret → SHOPIFY_API_SECRET

# BigCommerce app setup:
# 1. Create an API account / app in the BigCommerce Developer Portal
# 2. Set the Auth Callback URL to:
#    http://localhost:3000/api/integrations/bigcommerce/callback
#    https://<your-production-domain>/api/integrations/bigcommerce/callback
# 3. Request product + store information read scopes
# 4. Copy Client ID / Client Secret → BIGCOMMERCE_CLIENT_ID / BIGCOMMERCE_CLIENT_SECRET

# Amazon SP-API setup:
# 1. Register an SP-API app and LWA security profile
# 2. Set the OAuth redirect URI to:
#    http://localhost:3000/api/integrations/amazon/callback
#    https://<your-production-domain>/api/integrations/amazon/callback
# 3. Copy LWA credentials → AMAZON_LWA_CLIENT_ID / AMAZON_LWA_CLIENT_SECRET
# 4. Copy application ID → AMAZON_SP_API_APP_ID

# Squarespace developer platform setup:
# 1. Create an app and enable Commerce product/inventory read scopes
# 2. Set the redirect URI to:
#    http://localhost:3000/api/integrations/squarespace/callback
#    https://<your-production-domain>/api/integrations/squarespace/callback
# 3. Copy Client ID / Client Secret → SQUARESPACE_CLIENT_ID / SQUARESPACE_CLIENT_SECRET

# WooCommerce setup:
# 1. In WP Admin → WooCommerce → Settings → Advanced → REST API, create a Read key
# 2. In Product Agent, enter the store URL + consumer key/secret (no app credentials required)
# 3. Ensure TOKEN_ENCRYPTION_KEY (or another commerce secret) is set so keys are encrypted at rest

# Admin Center (internal). Access is granted manually in Supabase — there is no
# env allowlist or self-serve UI:
#   update public.profiles set is_platform_admin = true where email = 'you@example.com';
# Then open /admin/feedback
#
# Feedback fulfillment pipeline:
# 1. Approve feedback → generates a Cursor agent prompt
# 2. Approve prompt → launches Cursor cloud agent (CURSOR_API_KEY + CURSOR_GITHUB_REPO_URL)
# 3. Agent opens a PR into CURSOR_AGENT_BASE_REF (default: dev)
# 4. GitHub webhook on merge → emails the submitter (RESEND_API_KEY)