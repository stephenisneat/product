# Supabase (optional — omit for demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alias also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (optional — demo agent stream used when unset)
OPENAI_API_KEY=

# Demo session HMAC secret (optional in development)
DEMO_SESSION_SECRET=change-me-in-production

# Set to "true" to mark auth cookies Secure (also auto-enabled on Vercel)
# COOKIE_SECURE=true
